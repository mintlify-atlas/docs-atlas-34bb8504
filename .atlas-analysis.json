  "keyFeatures": [
    "Domain-configurable entity extraction for historical research",
    "Multi-model AI support (cloud Gemini and local Ollama via LiteLLM)",
    "Smart deduplication with RapidFuzz lexical blocking and embedding similarity",
    "Profile versioning and citation-backed grounding",
    "Privacy mode with local-only embeddings and no telemetry",
    "Parallel extraction pipeline with quality controls and caching",
    "FastHTML web interface with archival elegance design",
    "Merge dispute resolution with second-stage LLM arbitration"
  ],
  "publicApiSurface": [
    "process-domain - Process articles for a specific research domain",
    "init - Initialize a new research domain configuration",
    "frontend - Start the FastHTML web interface",
    "EntityExtractor - Unified cloud/local entity extraction",
    "EntityMerger - Deduplication with lexical blocking and embeddings",
    "ArticleProcessor - Relevance, extraction, and QC orchestration",
    "VersionedProfile - Profile history management",
    "EmbeddingManager - Cloud/local embedding providers",
    "DomainConfig - Domain configuration loader"
  ]
}
